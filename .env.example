# Database (로컬 Docker)
DATABASE_URL="postgresql://pcf:pcf@localhost:5432/pcf?schema=public"
# migrate deploy 에 사용. 로컬에서는 DATABASE_URL 과 동일하게 두면 됩니다.
DIRECT_URL="postgresql://pcf:pcf@localhost:5432/pcf?schema=public"

# --- Neon 배포 시 (Vercel 환경 변수에 설정) ---
# DATABASE_URL = Neon Dashboard → Connection string → "Pooled connection" (Prisma)
# DIRECT_URL   = Neon Dashboard → Connection string → "Direct connection" (마이그레이션용)
# 예시:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Fake API latency / failure simulation (영문 과제 요구사항)
NEXT_PUBLIC_SIMULATE_LATENCY=1
NEXT_PUBLIC_SIMULATE_FAILURE_RATE=0.15
NEXT_PUBLIC_SIMULATE_LATENCY_MIN_MS=200
NEXT_PUBLIC_SIMULATE_LATENCY_MAX_MS=800

# App
NEXT_PUBLIC_APP_NAME="PCF Emissions Dashboard"
